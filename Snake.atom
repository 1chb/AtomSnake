10 W=40
20 H=21
30 GOSUB i; REM "Init";
40 R=0; GOSUB p; REM "Play"
50 PRINT $27"["H+3";"1"H" $27"[?25h"
60 END
1000p REM === "Play" === => B AA : D G I J K L M N P Q
1010 GOSUB h; REM "HomePage";
1020 GOSUB n; REM "InitGame";
1030 L=20; REM Tick delay in centiseconds
1040 M=R+L; REM Next tick R
1050 REM Main game loop
1060q IF B=0 THEN RETURN
1070 REM c keyboard
1080 IF ?#410=?#411 THEN GOTO w; REM "WaitForTick"
1090 N=?(#400 +?#410); ?#410=(?#410 +1)&#F
1100 IF N=#38 THEN D=1; GOSUB d;
1110 IF N=#34 THEN D=0; GOSUB d;
1120 IF N=#36 THEN D=2; GOSUB d;
1125 IF N=#32 THEN D=3; GOSUB d;
1126 IF N=#50 THEN GOSUB o;
1127 IF N=27 THEN B=0;
1130w REM Wait for tick
1135 R=R+1
1140 IF R<M THEN GOTO q; REM "GameLoop"
1150 M=R+L; REM Schedule next tick
1160 GOSUB f
1170 GOTO q; REM "GameLoop"
1180o IF ?#410=?#411 THEN GOTO o; REM "PauseLoop"
1190 N=?(#400 +?#410); ?#410=(?#410 +1)&#F; IF N<>#50 THEN GOTO o; REM "PauseLoop"
1200 RETURN
2000a REM === "Adjust" === P Q => AA : I M N P
2010 I=0; M=Z;
2020 DO; AA(I)=AA(I)+Q
2030 N=M; M=M/2; I=I+I+1; REM Assume lower half
2040 IF P>=M THEN P=P-M; M=N-M; I=I+1; REM Otherwise upper half
2050 UNTIL I>=O
2060 RETURN
2100y REM === "Debug" === AA(0) J => : I
2130 RETURN
2200l REM === "Locate" === P => J : I K L M P
2210 P=P*8
2220 I=1; J=0; K=Z; DO; REM Interval [J..K]; upper limit is not included
2230 M=(K-J)/2; L=AA(I)&-8
2240 IF P<L THEN K=J+M; I=I+I+1
2250 IF P>=L THEN J=J+M; P=P-L; I=I+I+3
2260 UNTIL I>=O
2300g; REM Linear search:
2310 IF AA(J)&7 GOTO 2340; REM "2340"
2320 IF P=0 THEN RETURN
2330 P=P-8
2340 J=J+1
2350 IF J>=Z THEN GOSUB z; Here
2360 GOTO g; REM "LocateLinear"
3000b REM === "Border" === P => AA : M N Q P GOSUB m
3010r REM === "BorderPrim" === P => AA : M N Q P PRINT " "
3020 AA(P)=AA(P)|4
3030 E=I; F=P; REM Save some variables
3040 Q=-8; GOSUB a
3050 P=F; I=E; REM Restore the variables
3060 RETURN
3200m REM === "MoveTo" === P =>
3210 REM Centrate board
3220 PRINT $27"["P/W+3";"P%W+(42-W)/2"H"
3230 RETURN
4500n REM === "InitGame" === => S T D U AA : D G I J K L M N P Q
4510 S=(H+1)/2*W-W/2; REM Center of board
4520 T=S-2
4530 D=2; REM Go east
4540 FOR J=T TO S
4550 P=J; GOSUB m; PRINT "+"
4560 AA(P)=(AA(P)&-8)|4|D
4565 Q=-8; GOSUB a
4570 NEXT J
4580 FOR G=1 TO 5; GOSUB s; NEXT G
4590 GOTO y; REM "Debug"
5000d REM === "ChangeDirection" === S D => AA
5010 IF (AA(S)&3)=D THEN RETURN; REM Dir not changed
5020 AA(S)=(AA(S)&#FFFFFFFC)|D
5030 RETURN
5500s REM === "SpawnFood" === => J AA : I K L M N P Q
5520 P=ABS(RND)%(AA(0)/8)
5522 FOR I=1 TO 2;PRINT $27"["I ";"1"H"$27"#"I+2 P ".";NEXT I
5530 GOSUB l
5540 IF AA(J)&7 THEN GOSUB z; Here
5550 AA(J)=AA(J)+1
5560 P=J; GOSUB m; PRINT "@"
5570 Q=-8; GOSUB a
5575
5580 GOTO y; REM "Debug"
5800z REM === "Error" === => : M P
5810 FOR P=0 TO Z-1
5820 M=AA(P)&7
5830 GOSUB m; IF M>0 THEN PRINT M
5840 NEXT P
5850 PRINT $27"[?25h"
5860 RETURN
6000t REM === "StepSub" === P D => P
6020 P=P+(D&2-1)*((D&1)*(W-1)+1)
6030 RETURN
6500e REM === "EatTail" === => T AA : D I M N P Q
6510 P=T; Q=8; GOSUB a
6520 D=AA(T)
6530 AA(T)=D&-8
6540 P=T; GOSUB m; PRINT " "
6550 P=T; GOSUB t; T=P
6560 RETURN
6700f REM === "AdvanceHead" === => S T U B AA : D G I J K L M N P Q
6710 D=AA(S)&3
6720 P=S; GOSUB t; S=P
6740 IF AA(S)&4 THEN GOTO x; REM "Clash"
6750 G=D
6760 IF AA(S)&7=1 THEN GOTO v; REM "Eat"
6770 GOSUB e
6780 GOSUB u
6790 P=S; Q=-8; GOSUB a
6795 GOTO y; REM "Debug"
6800v
6820 U=U+1
6830 FOR I=1 TO 2; PRINT $27"["I ";"36"H"$27"#"I+2 U;NEXT I
6840 GOSUB s
6900u REM === "MarkHead" === G S => AA : D P
6910 D=G
6920 AA(S)=(AA(S)&-8)|4|D
6930 P=S; GOSUB m; PRINT "+"; GOSUB m; REM Looks better
6940 GOTO y; REM "Debug"
8000h REM === "HomePage" === => AA : I M N P Q
8010 PRINT $12 $27"[?25l"
8020 FOR I=1 TO 2; PRINT $27"["I ";"18"H"$27"#"I+2"Snake"; NEXT I
8025 FOR I=1 TO 2; PRINT $27"["I ";"30"H"$27"#"I+2"Score 0"; NEXT I
8030 FOR I=1 TO H; PRINT $10$13$27"#6"; NEXT I
8040 PRINT $27"[7m"
8050 REM TopBorder
8055 P=0; GOSUB m
8060 FOR P=0 TO W-1;GOSUB r;NEXT P
8080 REM SideBorders
8090 FOR I=W TO Z-W-W STEP W
8100 P=I; GOSUB b; REM LeftBorder
8110 P=I+W-1; GOSUB b; REM RightBorder
8120 NEXT I
8130 REM BottomBorder
8135 P=Z-W; GOSUB m
8140 FOR P=Z-W TO Z-1;GOSUB r;NEXT P
8160 PRINT $27"[m"
8170 RETURN
9000x REM === "Clash" === => B : I
9010 B=0
9020 FOR I=1 TO 2;
9030 PRINT $27"["H-1+I ";"2"H"$27"#"I+2"[GAME OVER!]";
9040 NEXT I
9050 RETURN
9800i REM === "Init" === W H => Z O U C B AA : I J K
9810 @=0
9820 Z=W*H; REM Z<3 not supported !!!!
9830 DIM AA(Z-1); REM Allocates (Z cells, 0-based)!
9900 PRINT "Initializing..."
9905 O=1;DO;O=O+O;UNTIL O+O>Z+1;O=O-1; REM Number of tree cells - O=2^n-1 - 3 7 15 31 ...
9907 REM TODO: Consider reduce number of O; e.g. O=O/2
9910 AA(0)=Z*8; REM See Bits above
9920 FOR I=1 TO O-2 STEP 2
9930 J=(I-1)/2
9940 K=AA(J)/2&-8; REM AA(J)/2/8*8
9950 AA(I)=K
9960 AA(I+1)=AA(J)-K
9970 NEXT I
9975 FOR I=O TO Z-1; AA(I)=0; NEXT I; REM Clear remaining O
9980 U=0; C=-1; B=1
9990 RETURN
