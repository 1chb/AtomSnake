10 W=40
20 H=21
30 GOSUB i; REM "Init"
40 GOSUB p; REM "Play"
50 END
1000p REM === "Play" ===
1010 GOSUB h
1020 GOSUB n
1030 L=20; REM Tick delay in centiseconds
1040 M=TIME+L; REM Next tick time
1050 REM Main game loop
1060q IF B=0 THEN RETURN
1070 REM Check keyboard
1080 IF ?#410=?#411 THEN GOTO 1130; REM "1130"
1090 N=?(#400 +?#410); ?#410=(?#410 +1)&#F
1100 IF N=91 THEN D=1; GOSUB d; REM Up [
1110 IF N=59 THEN D=0; GOSUB d; REM -1 ;
1120 IF N=44 THEN D=2; GOSUB d; REM 1
1125 IF N=47 THEN D=3; GOSUB d; REM /
1127 IF N=27 THEN B=0; REM Esc to quit
1130 REM Wait for tick
1140 IF TIME<M THEN GOTO q; REM "GameLoop"
1150 M=TIME+L; REM Schedule next tick
1160 GOSUB f
1170 GOTO q; REM "GameLoop"
2000a REM === "Adjust" ===(P, Q)
2010 I=0; K=Z; L=0
2020c IF I>=Z THEN RETURN
2030 IF P>=K THEN P=P-K; K=L; I=I+1
2040 AA(I)=AA(I)+Q
2050 I=2*I+1
2060 L=K/2
2070 K=K-L
2080 GOTO c; REM "AdjustLoop"
2200l REM === "Locate" ===(P=count 0<=p*8<AA(0), destroys p. Result in J)
2210 P=P*8
2220 I=1; J=0; K=Z; REM Interval [J..K]; upper limit is not included
2230k M=(K-J)/2; L=AA(I)&-8
2240 IF P<L THEN K=K-M; GOTO j; REM "LocateLeft"
2250 J=K-M; P=P-L; I=I+1
2260j I=2*I+1
2270 IF I<Z THEN GOTO k; REM "LocateLoop"
2280 REM Linear search:
2290g IF P=0 THEN RETURN
2300 IF AA(J)&7=0 THEN P=P-8
2310 J=J+1; GOTO g; REM "LocateLinear"
3000b REM === "Border" ===(P)
3010 GOSUB m; PRINT " "
3020 AA(P)=AA(P)|4
3030 E=I; F=P; REM Save some variables
3040 Q=-8; GOSUB a
3050 P=F; I=E; REM Restore the variables
3060 RETURN
3200m REM === "MoveTo" ===(P)
3210 REM Centrate board
3220 PRINT $27"["P/W+3";"P%W+(42-W)/2"H"
3230 RETURN
4500n REM === "InitSnake" ===
4510 S=(H+1)/2*W-W/2; REM Center of board
4520 T=S-2
4530 D=2; REM Go east
4540 FOR P=T TO S
4550 GOSUB m; PRINT "+"
4560 AA(P)=(AA(P)&-8)|4|D
4570 NEXT P
4580 RETURN
5000d REM === "ChangeDirection" ===
5010 IF (AA(S)&3)=D THEN RETURN; REM Direction not changed
5020 AA(S)=(AA(S)&~3)|D; REM ~3 = #FFFFFFFC
5030 RETURN
6000t REM === "StepSub" ===
6010 REM P=Pos D=Dir W=Width
6020 P=P+(D&2-1)*((D&1)*(W-1)+1)
6030 RETURN
6500e REM === "EatTail" ===
6510 P=T; Q=8; GOSUB a
6520 D=AA(T)
6530 AA(T)=D&-8
6540 P=T; V=" "; GOSUB 7000
6550 P=T; GOSUB t; T=P
6560 RETURN
6700f REM === "AdvanceHead" ===
6710 D=AA(S)&3
6720 P=S; GOSUB t; S=P
6730 M=AA(S)
6740 IF M&4 THEN GOSUB 9000; RETURN
6750 P=S; Q=-8; GOSUB a
6760 AA(S)=(M&-8)|4|D
6770 P=S; V="+"; GOSUB 7000
6780 GOSUB e
6790 RETURN
7000w REM === "Draw" ===
7010 REM P=Position V=String
7020 K=P%W+(40-W)/2
7030 PRINT $27"["P/W+2";"K "H" V
7040 RETURN
8000h REM === "HomePage" ===
8010 PRINT $12
8020 FOR I=1 TO 2; PRINT $27"["I ";"18"H"$27"#"I+2"Snake"; NEXT I
8030 FOR I=1 TO H; PRINT ' $27"#6"; NEXT I
8040 PRINT $27"[7m"
8050 FOR P=0 TO W-1; GOSUB b; NEXT P; REM TopBorder
8060 FOR I=W TO Z-W-W STEP W
8070 P=I; GOSUB b; REM LeftBorder
8080 P=I+W-1; GOSUB b; REM RightBorder
8090 NEXT I
8100 FOR P=Z-W TO Z-1; GOSUB b; NEXT P; REM BottomBorder
8110 PRINT $27"[m"
8120 RETURN
9000x REM === "Clash" ===
9010 B=0
9020 PRINT $27"["H+4";"1"H""GAME OVER!"
9030 RETURN
9800i REM === "Init" ===
9810 @=0
9820 Z=W*H
9830 DIM AA(Z); REM Allocates (Z+1)!
9840 GOTO r; REM "Reset"
9900r REM === "Reset" ===
9905 PRINT "Initializing..."
9910 AA(0)=Z*8; REM See Bits above
9920 FOR I=1 TO Z-1 STEP 2
9930 J=(I-1)/2
9940 K=AA(J)/2&-8; REM AA(J)/2/8*8
9950 AA(I+1)=K
9960 AA(I)=AA(J)-K
9970 NEXT I
9980 U=0; C=-1; B=1
9990 RETURN
