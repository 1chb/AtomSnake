10 W=40
20 H=21
30 GOSUB i; REM "Init";
40 R=0; GOSUB p; REM "Play"
50 PRINT $27"["H+3";"1"H" $27"[?25h"
60 END
1000p REM === "Play" === => B A Y AA : D G I J K L M N P Q
1010 GOSUB h; REM "HomePage";
1020 GOSUB n; REM "InitGame";
1030 A=20; REM Tick delay in loop iterations
1040 Y=R+A; REM Next tick R
1100q IF B=0 THEN RETURN
1110 IF ?#410=?#411 THEN GOTO w; REM "WaitForTick"
1120 N=?(#400 +?#410); ?#410=(?#410 +1)&#F
1130 IF N=#38 THEN D=1; GOSUB d;
1140 IF N=#34 THEN D=0; GOSUB d;
1150 IF N=#36 THEN D=2; GOSUB d;
1160 IF N=#32 THEN D=3; GOSUB d;
1170 IF N=#35 THEN GOSUB o;
1180 IF N=27 THEN B=0;
1200w R=R+1
1210 IF R<Y THEN GOTO q; REM "GameLoop"
1220 Y=R+A; REM Schedule next tick
1230 GOSUB f
1240 GOTO q; REM "GameLoop"
1300o REM === "PauseLoop" === => : N
1310 DO; DO; UNTIL ?#410<>?#411
1320 N=?(#400 +?#410); ?#410=(?#410 +1)&#F
1330 UNTIL N=#35
1340 RETURN
2000a REM === "Adjust" === P Q => AA : I M N P
2010 I=0; M=Z;
2020 DO; AA(I)=AA(I)+Q
2030 N=M; M=M/2; I=I+I+1; REM Assume lower half
2040 IF P>=M THEN P=P-M; M=N-M; I=I+1; REM Otherwise upper half
2050 UNTIL I>=O
2060 RETURN
2100y REM === "Debug" === AA(0) J => : I
2130 RETURN
2200l REM === "Locate" === P => J : I K L M P
2210 P=P*8
2220 I=1; J=0; K=Z; DO; REM Interval [J..K]; upper limit is not included
2230 M=(K-J)/2; L=AA(I)&-8
2240 IF P<L THEN K=J+M; I=I+I+1
2250 IF P>=L THEN J=J+M; P=P-L; I=I+I+3
2260 UNTIL I>=O
2300g; REM Linear search:
2310 IF AA(J)&7 GOTO j; REM "LocateSkip"
2320 IF P=0 THEN RETURN
2330 P=P-8
2340j J=J+1
2350 IF J>=Z THEN GOSUB z; Here
2360 GOTO g; REM "LocateLinear"
3000b REM === "Border" === P => AA : M N Q P PRINT $27"["P/W+3";"P%W+(42-W)/2"H"
3010r REM === "BorderPrim" === P => AA : M N Q P PRINT " "
3020 AA(P)=AA(P)|4
3030 E=I; G=P; REM Save some variables
3040 Q=-8; GOSUB a
3050 P=G; I=E; REM Restore the variables
3060 RETURN
4000n REM === "InitGame" === => S T D U E X V AA : D G I J K L M N P Q
4010 S=(H+1)/2*W-W/2; REM Center of board
4020 T=S-2
4030 D=2; REM Go east
4040 FOR J=T TO S
4050 PRINT $27"["J/W+3";"J%W+(42-W)/2"H" $27"(0" "q" $27"(B"
4060 AA(J)=(AA(J)&-8)|4|D
4070 P=J; Q=-8; GOSUB a
4080 NEXT J
4090 E=2; X=0; V=0
4100 PRINT $27"["S/W+3";"S%W+(42-W)/2"H" $27"(0" "`" $27"(B"
4110 FOR G=1 TO 5; GOSUB s; NEXT G
4120 GOTO y; REM "Debug"
5000d REM === "ChangeDirection" === S D => AA
5010 IF (AA(S)&3)=D THEN RETURN; REM Dir not changed
5020 AA(S)=(AA(S)&#FFFFFFFC)|D
5030 RETURN
5100s REM === "SpawnFood" === => J X V AA : I K L M N P Q
5110 IF AA(0)&-8=0 THEN RETURN
5120 P=ABS(RND)%(AA(0)/8)
5130 FOR I=1 TO 2;PRINT $27"["I ";"1"H"$27"#"I+2 P "  ";NEXT I
5140 GOSUB l
5150 IF AA(J)&7 THEN GOSUB z; Here
5155 N=1; REM Default: regular food
5157 IF V=0 AND J%13=5 THEN N=2; V=1
5160 AA(J)=AA(J)+N
5170 PRINT $27"["J/W+3";"J%W+(42-W)/2"H" $(F+15)?N
5180 P=J; Q=-8; GOSUB a
5190 X=X+1;
5200 GOTO y; REM "Debug"
5300z REM === "Error" === => : M P
5310 FOR P=0 TO Z-1
5320 M=AA(P)&7
5330 IF M>0 THEN PRINT $27"["P/W+3";"P%W+(42-W)/2"H" M
5340 NEXT P
5350 PRINT $27"[?25h"
5360 RETURN
6000t REM === "StepSub" === P D => P
6010 P=P+(D&2-1)*((D&1)*(W-1)+1)
6020 RETURN
6100e REM === "EatTail" === => T AA : D I M N P Q
6110 P=T; Q=8; GOSUB a
6120 D=AA(T)
6130 AA(T)=D&-8
6140 PRINT $27"["T/W+3";"T%W+(42-W)/2"H" " "
6150 P=T; GOSUB t; T=P
6160 RETURN
6200f REM === "AdvanceHead" === => S T U B X V AA E : D G I J K L M N P Q
6210 D=AA(S)&3
6220 N=F?(E*4+D)
6230 PRINT $27"["S/W+3";"S%W+(42-W)/2"H" $27"(0" $N $27"(B"
6240 E=D
6250 P=S; GOSUB t; S=P
6260 IF AA(S)&4 THEN GOTO x; REM "GameOver"
6270 G=D
6280 IF AA(S)&7 THEN GOTO v; REM "Eat"
6290 GOSUB e
6300 GOSUB u
6310 P=S; Q=-8; GOSUB a
6320 GOTO y; REM "Debug"
6400v
6410 X=X-1
6420 U=U+1
6430 IF AA(S)&7=2 THEN U=U+2; V=0
6440 FOR I=1 TO 2; PRINT $27"["I ";"36"H"$27"#"I+2 U;NEXT I
6450 GOSUB s
6500u REM === "MarkHead" === G S => AA : D P
6510 D=G
6520 AA(S)=(AA(S)&-8)|4|D
6530 PRINT $27"["S/W+3";"S%W+(42-W)/2"H" $27"(0" "`" $27"(B"
6540 PRINT $27"["S/W+3";"S%W+(42-W)/2"H"; REM Reposition cursor
6550 GOTO y; REM "Debug"
8000h REM === "HomePage" === => AA : I M N P Q
8010 PRINT $12 $27"[?25l"
8020 FOR I=1 TO 2; PRINT $27"["I ";"18"H"$27"#"I+2"Snake"; NEXT I
8030 FOR I=1 TO 2; PRINT $27"["I ";"30"H"$27"#"I+2"Score 0"; NEXT I
8040 FOR I=1 TO H; PRINT $10$13$27"#6"; NEXT I
8050 PRINT $27"[7m"
8055 REM TopBorder
8060 PRINT $27"["0/W+3";"0%W+(42-W)/2"H"
8070 FOR P=0 TO W-1;GOSUB r;NEXT P
8075 REM SideBorders
8080 FOR I=W TO Z-W-W STEP W
8090 P=I; GOSUB b; REM LeftBorder
8100 P=I+W-1; GOSUB b; REM RightBorder
8110 NEXT I
8115 REM BottomBorder
8120 PRINT $27"["(Z-W)/W+3";"(Z-W)%W+(42-W)/2"H"
8130 FOR P=Z-W TO Z-1;GOSUB r;NEXT P
8140 PRINT $27"[m"
8150 RETURN
9000x REM === "GameOver" === S X => B : I P
9010 B=0; PRINT $27"["S/W+3";"S%W+(42-W)/2"H"
9020 IF X>0 THEN GOTO m; REM "Lose"
9030 PRINT $27"(0" "`" $27"(B"
9040 FOR I=1 TO 2; PRINT $27"["I ";"1"H"$27"#"I+2"You Win!"; NEXT I
9050 RETURN
9100m PRINT "X"
9110 FOR I=1 TO 2; PRINT $27"["I ";"1"H"$27"#"I+2"Loser!"; NEXT I
9120 RETURN
9800i REM === "Init" === W H => Z O U C B F AA : I J K
9810 @=0
9820 Z=W*H; REM Z<3 not supported !!!!
9830 DIM AA(Z-1); REM Allocates (Z cells, 0-based)!
9840 PRINT "Initializing..."
9850 O=1;DO;O=O+O;UNTIL O+O>Z+1;O=O-1; REM Number of tree cells - O=2^n-1 - 3 7 15 31 ...
9855 REM TODO: Consider reduce number of O; e.g. O=O/2
9860 AA(0)=Z*8; REM See Bits above
9870 FOR I=1 TO O-2 STEP 2
9880 J=(I-1)/2
9890 K=AA(J)/2&-8; REM AA(J)/2/8*8
9900 AA(I)=K
9910 AA(I+1)=AA(J)-K
9920 NEXT I
9930 FOR I=O TO Z-1; AA(I)=0; NEXT I; REM Clear remaining O
9940 U=0; C=-1; B=1
9950 REM Snake body LUT: F?(E*4+D) => line drawing char
9955 REM Directions: W=0 N=1 E=2 S=3. Graphics: q=─ x=│ j=┘ k=┐ l=┌ m=└. Food: @=1 *=2
9960 DIM F(18); $F="qmnlkxlnnjqkjnmx@*"
9970 RETURN
